{
  "name": "@puckeditor/plugin-views",
  "version": "0.6.0",
  "author": "Chris Villa <chris@puckeditor.com>",
  "repository": "puckeditor/puck",
  "bugs": "https://github.com/puckeditor/puck/issues",
  "homepage": "https://puckeditor.com",
  "keywords": [
    "puck-ecosystem",
    "puck-plugin"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./configure": {
      "types": "./dist/configure.d.ts",
      "import": "./dist/configure.mjs",
      "require": "./dist/configure.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "scripts": {
    "lint": "eslint \"**/*.ts*\"",
    "build": "rm -rf dist && tsup index.ts configure.ts",
    "dev": "tsup index.ts configure.ts --watch src"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@puckeditor/core": "0.21.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "eslint": "^7.32.0",
    "eslint-config-custom": "workspace:*",
    "lucide-react": "^0.452.0",
    "tsconfig": "workspace:*",
    "tsup": "^8.2.4",
    "tsup-config": "workspace:*",
    "typescript": "^5.5.4"
  },
  "peerDependencies": {
    "@puckeditor/core": "^0.21.0 || 0.21.0-canary.de0baf39",
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "qler": "^0.6.2"
  }
}
