{
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=demo",
    "lint": "turbo run lint",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,mdx,css}\"",
    "format": "prettier --write \"**/*.{ts,tsx,md,mdx,css}\"",
    "release": "pnpm release:prepare && pnpm changelog && pnpm release-commit",
    "release:prepare": "git fetch --tags && conventional-recommended-bump -p angular | xargs pnpm version:auto $1",
    "release:canary": "pnpm release:prepare && node scripts/get-unstable-version canary | xargs pnpm version:auto $1",
    "release-commit": "git add -u && git commit -m \"release: v${npm_package_version}\"",
    "smoke": "node scripts/e2e/smoke.mjs",
    "test": "turbo run test",
    "version": "lerna version --force-publish -y --no-push --no-changelog --no-git-tag-version $npm_package_version",
    "version:auto": "npm version --no-git-tag-version $1",
    "changelog": "node scripts/create-changelog"
  },
  "devDependencies": {
    "asciichart": "^1.5.25",
    "conventional-changelog-angular": "^8.3.1",
    "conventional-recommended-bump": "^11.2.0",
    "eslint": "^9.0.0",
    "eslint-config-custom": "workspace:*",
    "lerna": "^9.0.7",
    "prettier": "^2.5.1",
    "puppeteer": "^24.8.2",
    "rimraf": "^6.1.3",
    "standard-changelog": "^2.0.21",
    "turbo": "^2.5.8"
  },
  "name": "puck-repo",
  "packageManager": "pnpm@9.15.9",
  "version": "0.21.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "overrides": {
      "yaml": ">=2.8.3",
      "zod-validation-error": "^4.0.0"
    }
  }
}
